generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pqrs {
  id              String   @id @default(uuid())
  texto           String
  sourceType      String?  @default("manual_text")
  canal           String
  remitente       String?
  asunto          String?
  adjuntos        Json?
  tipo            String?
  tema            String?
  subtema         String?
  urgencia        String?
  entidad         String?
  riesgo          String?
  resumen         String?
  confianza       Float?
  estado          String   @default("pendiente")
  ocrUsado        Boolean  @default(false)
  advertenciaOcr  Boolean  @default(false)
  pipelineTrace   Json?
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  auditLogs AuditLog[]

  @@map("pqrs")
}

model AuditLog {
  id        String   @id @default(uuid())
  pqrsId    String
  accion    String
  usuario   String
  detalles  Json?
  createdAt DateTime @default(now())

  pqrs Pqrs @relation(fields: [pqrsId], references: [id])

  @@map("audit_logs")
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}
